# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars (it's gitignored).
project_id       = "inventory-496204"
region           = "asia-northeast1"
bigquery_dataset = "product_system"
db_password      = "REPLACE_WITH_A_STRONG_PASSWORD"

# Leave service_image unset on first apply — the default placeholder
# (us-docker.pkg.dev/cloudrun/container/hello) lets Terraform finish.
# After we build the real image, redeploy via `gcloud run deploy ...`.
# service_image = "asia-northeast1-docker.pkg.dev/inventory-496204/product-system/app:v0.1.0"

# ---- Phase 1-B Stage 0 verification jobs (docs/14) ----
# Set true to deploy the 4 verification Cloud Run Jobs + recon scratch bucket
# for Stage 1 verification; set back to false to tear them down. Requires
# service_image to point at a real image that bundles scripts/*.py.
# create_verification_jobs = false
#
# Flip true only after the client delivers SLACK_WEBHOOK_URL (D-3) AND you have
# pushed a secret version (gcloud secrets versions add slack-webhook-url ...).
# slack_webhook_secret_ready = false
#
# Override only if "product-system-verify" is already taken (bucket names are
# globally unique).
# recon_verify_bucket = "product-system-verify"

# Artifact Registry: leave false unless you have imported the existing repo
# (see artifact_registry.tf). cloudbuild.yaml pushes here regardless.
# manage_artifact_registry = false
# artifact_registry_repo   = "product-system"
