# ===================================================================
# Product System — Environment variables (Phase 1-A)
# Copy this file to `.env` and fill in actual values for local dev.
# In production, these are sourced from Secret Manager / Cloud Run env.
# ===================================================================

# ----- App -----
APP_ENV=local                       # local | dev | staging | prod
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Tokyo

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/product_system
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/product_system

# ----- Task queue (Cloud Tasks abstraction) -----
TASK_QUEUE_BACKEND=in_memory        # in_memory | cloud_tasks

# ----- Rakuten RMS API (filled at Sprint 5 with client credentials) -----
RAKUTEN_SERVICE_SECRET=
RAKUTEN_LICENSE_KEY=
RAKUTEN_SHOP_URL=

# ----- Shopify Admin API (filled at Sprint 5 with client credentials) -----
SHOPIFY_SHOP_DOMAIN=                # e.g. yourshop.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2025-04

# ----- GCP (filled at Sprint 5) -----
GCP_PROJECT_ID=
GCP_REGION=asia-northeast1
BIGQUERY_DATASET=

# ----- Admin UI auth (Phase 1-A: simple basic auth, will be replaced) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
